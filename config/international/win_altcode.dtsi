/*
 * Windows Alt Code — DRY macro generators
 *
 * Generates ZMK macros for Windows ANSI alt codes (0xxx format).
 * Method: hold LALT → type 0 + 3 digits on numpad → release LALT
 * Requires NumLock ON in the host OS.
 *
 * ┌──────────────────────────────────────────────────────────┐
 * │  WIN_ALTCODE(name, d1, d2, d3)                          │
 * │    → mac_<name>    (single character, e.g. ß)           │
 * │                                                         │
 * │  WIN_ALTCODE_PAIR(name, d1,d2,d3, D1,D2,D3)            │
 * │    → mac_<name>          (lowercase, e.g. á)            │
 * │    → mac_<name>_upper    (uppercase, e.g. Á)            │
 * │                                                         │
 * │  MOD_MORPH_SHIFT(name)                                  │
 * │    → mm_<name>           (shift-aware wrapper)          │
 * └──────────────────────────────────────────────────────────┘
 */

#define _KP(d) KP_N ## d

/* Single character: Alt + 0<d1><d2><d3> */
#define WIN_ALTCODE(name, d1, d2, d3) \
    mac_ ## name: mac_ ## name { \
        compatible = "zmk,behavior-macro"; \
        #binding-cells = <0>; \
        wait-ms = <40>; \
        tap-ms = <40>; \
        bindings \
            = <&macro_press &kp LALT> \
            , <&macro_tap &kp KP_N0 &kp _KP(d1) &kp _KP(d2) &kp _KP(d3)> \
            , <&macro_release &kp LALT>; \
    };

/* Character pair: lowercase Alt+0<d1d2d3>, uppercase Alt+0<D1D2D3> */
#define WIN_ALTCODE_PAIR(name, d1, d2, d3, D1, D2, D3) \
    mac_ ## name: mac_ ## name { \
        compatible = "zmk,behavior-macro"; \
        #binding-cells = <0>; \
        wait-ms = <40>; \
        tap-ms = <40>; \
        bindings \
            = <&macro_press &kp LALT> \
            , <&macro_tap &kp KP_N0 &kp _KP(d1) &kp _KP(d2) &kp _KP(d3)> \
            , <&macro_release &kp LALT>; \
    }; \
    mac_ ## name ## _upper: mac_ ## name ## _upper { \
        compatible = "zmk,behavior-macro"; \
        #binding-cells = <0>; \
        wait-ms = <40>; \
        tap-ms = <40>; \
        bindings \
            = <&macro_press &kp LALT> \
            , <&macro_tap &kp KP_N0 &kp _KP(D1) &kp _KP(D2) &kp _KP(D3)> \
            , <&macro_release &kp LALT>; \
    };

/* Shift-aware mod-morph (requires prior WIN_ALTCODE_PAIR) */
#define MOD_MORPH_SHIFT(name) \
    mm_ ## name: mm_ ## name { \
        compatible = "zmk,behavior-mod-morph"; \
        #binding-cells = <0>; \
        bindings = <&mac_ ## name>, <&mac_ ## name ## _upper>; \
        mods = <(MOD_LSFT|MOD_RSFT)>; \
    };
