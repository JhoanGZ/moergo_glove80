/*
 * Compose / Hyper Key
 *
 * Hold → Hyper (Ctrl + Alt + Shift + GUI)
 * Tap  → Sticky Accent layer (áéíóú ñ ß)
 *
 * From Accent layer, tap the same key again → Umlaut layer (äöü ß)
 *
 * In keymap:  &compose_hyper 0 LAYER_Accent
 *
 * Requires NumLock ON for alt codes. Activate once from Lower layer.
 */

#define LAYER_Accent 4
#define LAYER_Umlaut 5

#include "spanish.dtsi"
#include "german.dtsi"

/ {
    macros {
        hyper_macro: hyper_macro {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <0>;
            bindings
                = <&macro_press &kp LCTRL &kp LALT &kp LSHFT &kp LGUI>
                , <&macro_pause_for_release>
                , <&macro_release &kp LCTRL &kp LALT &kp LSHFT &kp LGUI>;
        };
    };

    behaviors {
        compose_hyper: compose_hyper {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <100>;
            bindings = <&hyper_macro>, <&sl>;
        };
    };
};
